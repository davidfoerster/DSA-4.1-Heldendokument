#!/bin/bash
set -eu
exec <&-

sub_help(){
	printf \
'Benutzung: %s <unterkommando> [options] <datei>

Unterkommandos:
    pdf            baue ein PDF mit Namen <datei ohne .lua>.pdf
        [-w|--white]
                   weißer Hintergrund statt der Karte
        [-g|-gg]   (Super-)-Go-Modus [siehe latexmk]
        <datei>    Lua-Datei, die die Heldendaten enthält

    ereignisse     zeige Tabelle aller Steigerungsereignisse
        <datei>    Lua-Datei, die die Heldendaten enthält

    import         importiere einen Held aus der Heldensoftware.
                   gibt Lua-Daten auf der Standardausgabe aus.
        <datei>    XML-Datei, die einen aus der Heldensoftware exportierten
                   Helden enthält.

    validate       Validiere eine gegebene Lua-Datei gegen das Schema.
        <datei>    Lua-Datei, die die Heldendaten enthält.
'	"${BASH_ARGV0##*/}"
}

sub_opterrmsg(){
	exec >&2
	local fmt= progname="$BASH_ARGV0" shortname="${BASH_ARGV0%%*/}"
	if [ "$shortname" != "$progname" ] && [ "$progname" -ef "$(type -P -- "$shortname")" ]; then
		progname="$shortname"
	fi
	if [ "$#" -eq 1 ]; then
		fmt='%s\n'
	elif [ "$#" -gt 1 ]; then
		fmt="$1\\n"
		shift
	fi
	printf -- "$fmt"'Führe "%s help" für Hilfe aus.\n' "$@" "$progname"
	exit 64
}

sub_pdf(){
	local BASE_NAME=heldendokument SOURCE_DATE_EPOCH src srcdir jobname
	local -a latexmk_options=()
	while :; do
		case "${1-}" in
			-w|--white)
				BASE_NAME=heldendokument-weiss;;
			-[cCg]*)
				latexmk_options+=("$1");;
			--)
				shift; break;;
			-?*)
				sub_opterrmsg 'Unbekannte Kommandozeilenoption: "%s"' "$1";;
			*)
				break;;
		esac
		shift
	done
	src="${1-}"
	if [ -z "$src" ]; then
		sub_opterrmsg 'Pfad zur Heldendatei muss als Eingabe angegeben werden!'
	fi
	if [ "$#" -gt 1 ]; then
		exec >&2
		echo -n 'Zu viele Kommandozeilenargumente:'
		shift
		printf ' "%s"' "$@"
		echo
		sub_opterrmsg
	fi
	jobname="${src##*/}"
	jobname="${jobname%.lua}"
	SOURCE_DATE_EPOCH="$(date -r "$src" '+%s')"
	[[ "$src" == /* ]] || src="$PWD/$src"
	srcdir="${src%/*}"
	cd -- "$SOURCES/src"
	export SOURCE_DATE_EPOCH
	exec latexmk \
		-lualatex="lualatex %O %S '${src//\'/\'\\\'\'}'" -jobname="$jobname" \
		-output-directory="$srcdir" -aux-directory="${TMPDIR:-/tmp}/latexmk" \
		-interaction=batchmode -halt-on-error -shell-escape \
		${latexmk_options[@]:+"${latexmk_options[@]}"} \
		-cd "$SOURCES/src/$BASE_NAME.tex"
}

sub_ereignisse(){
	local ABS_INPUT="$1"
	[[ "$ABS_INPUT" == /* ]] || ABS_INPUT="$PWD/$ABS_INPUT"
	cd -- "$SOURCES/src"
	exec texlua tools.lua list "$ABS_INPUT"
}

sub_import(){
	exec xsltproc "$SOURCES/share/import.xsl" "$1"
}

sub_validate(){
	local ABS_INPUT="$1"
	[[ "$ABS_INPUT" == /* ]] || ABS_INPUT="$PWD/$ABS_INPUT"
	cd -- "$SOURCES/src"
	exec texlua tools.lua validate "$ABS_INPUT"
}

case "${1-}" in
	-h|--help|help)
		sub_help
		;;
	pdf|ereignisse|import|validate)
		if [ -L "$0" ]; then
			SOURCES="$(readlink -f -- "$0")"
		else
			SOURCES="$0"
		fi
		SOURCES="${SOURCES%/*}"
		SOURCES="${SOURCES%/bin}"
		cmd="sub_$1"
		shift
		"$cmd" "$@"
		;;
	*)
		sub_opterrmsg 'Fehler: unbekanntes Unterkommando "%s"' "${1-}"
		;;
esac
